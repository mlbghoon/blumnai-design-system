  "ringAndDotBadges": {
    "description": "Structure for Online, Offline, Notification badges",
    "variants": ["online", "offline", "notification"],
    "badgeStructure": {
      "container": {
        "size": "16×16 fixed",
        "type": "div with relative positioning"
      },
      "ring": {
        "nodeId": "13202:4003",
        "name": "Ring",
        "position": {
          "css": "inset-[12.5%]",
          "calculation": "16px × 12.5% = 2px from each edge",
          "absolutePosition": "top: 2px, left: 2px",
          "containerSize": "12×12 (16 - 4 = 12)"
        },
        "element": {
          "type": "div with absolute inset-0",
          "contains": "SVG image (img tag)",
          "svgSize": "12×12",
          "color": "rgba(255, 255, 255, 1) - white",
          "fill": "--fill-0: rgba(255, 255, 255, 1)"
        },
        "structure": [
          "<div className='absolute inset-[12.5%]'>",
          "  <div className='absolute inset-0'>",
          "    <img src={ringSvg} width='12' height='12' />",
          "  </div>",
          "</div>"
        ]
      },
      "dot": {
        "nodeId": "13202:4004",
        "name": "Dot",
        "position": {
          "css": "inset-[20.83%]",
          "calculation": "16px × 20.83% = 3.333px from each edge",
          "absolutePosition": "top: 3.333px, left: 3.333px",
          "containerSize": "9.333×9.333 (16 - 6.667 = 9.333)"
        },
        "element": {
          "type": "div with absolute inset-0",
          "contains": "SVG image (img tag)",
          "svgSize": "9.333×9.333",
          "colors": {
            "online": "rgba(144, 205, 34, 1) - green #90CD22",
            "offline": "rgba(39, 39, 42, 1) - gray #27272a",
            "notification": "rgba(231, 67, 65, 1) - red #e74341"
          },
          "fill": "--fill-0: varies by variant"
        },
        "structure": [
          "<div className='absolute inset-[20.83%]'>",
          "  <div className='absolute inset-0'>",
          "    <img src={dotSvg} width='9.333' height='9.333' />",
          "  </div>",
          "</div>"
        ]
      },
      "completeStructure": {
        "tsx": [
          "<div className={statusBadge} style={{ width: '16px', height: '16px' }}>",
          "  {/* Ring at 12.5% inset = 12×12 container */}",
          "  <div className='absolute inset-[12.5%]'>",
          "    <div className='absolute inset-0'>",
          "      <img src={ringSvg} width='12' height='12' alt='' />",
          "    </div>",
          "  </div>",
          "  {/* Dot at 20.83% inset = 9.333×9.333 container */}",
          "  <div className='absolute inset-[20.83%]'>",
          "    <div className='absolute inset-0'>",
          "      <img src={dotSvg} width='9.333' height='9.333' alt='' />",
          "    </div>",
          "  </div>",
          "</div>"
        ]
      }
    }
  },
  "insetCalculations": {
    "for16pxBadge": {
      "ring": {
        "inset": "12.5%",
        "calculation": "16px × 0.125 = 2px",
        "result": "Ring container: top: 2px, left: 2px, width: 12px, height: 12px",
