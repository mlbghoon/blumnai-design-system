  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "npm run prebuild:lib && vite build --mode lib && tsc --project tsconfig.lib.json && tsc-alias --project tsconfig.lib.json && node scripts/strip-css-layers.mjs && node scripts/inject-use-client.mjs && node scripts/generate-subpath-proxies.mjs",
    "prebuild:lib": "npm run clean:thumbnail-sources && npm run generate:icons && npm run generate:file-icons && npm run generate:flag-registry && npm run generate:ui-icon-registry && npm run generate:isometric-icons && npm run generate:icon-catalog",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "NODE_OPTIONS='--max-old-space-size=8192' storybook dev -p 6006",
    "build-storybook": "NODE_OPTIONS='--max-old-space-size=8192' storybook build",
    "extract:icons": "node scripts/extract-icons-to-svg.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "generate:file-icons": "node scripts/generate-file-icons.mjs",
    "generate:flag-registry": "node scripts/generate-flags-icons.mjs",
    "generate:ui-icon-registry": "node scripts/generate-ui-icon-registry.mjs",
    "generate:isometric-icons": "node scripts/generate-isometric-icons.mjs",
    "generate:icon-catalog": "node scripts/generate-icon-catalog.mjs",
    "clean:thumbnail-sources": "node scripts/clean-svg-source-thumbnails.mjs && node scripts/clean-thumbnail-base64.mjs",
    "prebuild": "npm run clean:thumbnail-sources && npm run generate:icons && npm run generate:file-icons && npm run generate:flag-registry && npm run generate:ui-icon-registry && npm run generate:isometric-icons",
    "prestorybook": "npm run clean:thumbnail-sources && npm run generate:icons && npm run generate:file-icons && npm run generate:flag-registry && npm run generate:ui-icon-registry && npm run generate:isometric-icons",
    "test:visual": "playwright test",
    "test:visual:ui": "playwright test --ui",
    "test:visual:update": "playwright test --update-snapshots",
    "prepublishOnly": "npm run build:lib"
  },
