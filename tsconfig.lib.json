{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/index.ts", "src/components/**/*", "src/lib/**/*", "src/hooks/**/*", "src/constants/**/*", "src/utils/**/*"],
  "exclude": ["**/*.stories.tsx", "**/*.test.tsx", "**/*.spec.tsx", "src/App.tsx", "src/main.tsx"]
}
